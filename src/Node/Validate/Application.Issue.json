{
  "Application": {
    "Issue": {
      "create": {
        "validate": {
          "uuid": [
            {
              "is.uuid": true
            }
          ],
          "user": [
            {
              "is.uuid": true
            }
          ],
          "title": [
            {
              "is.unique": {
                "class": "Application.Issue",
                "attribute": [
                  "title"
                ]
              }
            },
            {
              "string.length": ">=3"
            },
            {
              "string.length": "<=80"
            }
          ],
          "description": [
            {
              "is.array": true
            }
          ],
          "type": [
            {
              "in.array": [
                "bug",
                "feature",
                "question"
              ]
            }
          ]
        }
      },
      "put": {
