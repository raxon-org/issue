{
  "Application": {
    "Issue": {
      "create": {
        "validate": {
          "uuid": [
            {
              "is.uuid": true
            }
          ],
          "user": [
            {
              "is.uuid": true
            }
          ],
          "title": [
            {
              "is.unique": {
                "class": "Application.Issue",
                "attribute": [
                  "title"
                ]
              }
            },
            {
              "string.length": ">=3"
            },
            {
              "string.length": "<=80"
            }
          ],
          "description": [
            {
              "is.array": true
            },
            {
              "in.array.word.count": ">= 3"
            },
            {
              "in.array.word.count": "<= 50"
            }
          ],
          "priority": [
            {
              "in.array": [
                "low",
                "medium",
                "high",
                "critical"
              ]
            }
          ],
          "status": [
            {
              "in.array": [
                "open",
                "processing",
                "closed"
              ]
            }
          ]
        }
      },
